# Secret para Payload CMS (mínimo 32 caracteres aleatorios)
PAYLOAD_SECRET=cambia-esto-por-un-secret-seguro-de-32-chars

# URL del sitio
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

